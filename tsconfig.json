{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM"],
    "types": ["@webgpu/types"],
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src"]
}
